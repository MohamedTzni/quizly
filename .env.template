# Django secret key. Generate one at https://djecrety.ir/
SECRET_KEY=your-django-secret-key-here

# Set to True during development, False in production.
DEBUG=True

# Comma-separated list of allowed hostnames.
ALLOWED_HOSTS=localhost,127.0.0.1

# Gemini API key for quiz generation. Create one at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: absolute path to the folder that contains the FFmpeg binary.
# Leave empty if FFmpeg is already on your system PATH.
# Windows example: FFMPEG_PATH=C:\ffmpeg\bin
FFMPEG_PATH=

# Optional: absolute path to the Node.js executable.
# Leave empty in most cases. Required only when YouTube demands a JavaScript
# runtime for certain restricted videos (yt-dlp will then delegate to Node.js).
# Windows example: NODE_PATH=C:\Program Files\nodejs\node.exe
NODE_PATH=
